---
import { loadPortfolio } from '../lib/resume.ts';

const PORTFOLIO = await loadPortfolio();

const bold = PORTFOLIO.work.find((w) => w.id === 'flottando')!;
const titleWords = bold.title.split(' ');
const titleHead = titleWords.slice(0, -1).join(' ');
const titleTail = titleWords[titleWords.length - 1];

const meta: [string, string][] = [
  ['Year', bold.year],
  ['Role', bold.role],
  ['Client', `${bold.client} · ${bold.location}`],
  ['№', bold.n],
];
---

<section
  id="flottando"
  data-nav="flottando"
  data-reveal
  data-spotlight
  class="bg-bold text-bold-fg px-gutter relative overflow-hidden py-[90px] md:py-[130px]"
>
  <div
    aria-hidden="true"
    class="bg-accent absolute inset-y-[78px] left-12 hidden w-[3px] opacity-90 min-[1500px]:block"
  >
  </div>

  <div class="container-page relative">
    <div
      data-reveal
      class="mb-7 flex flex-wrap items-center gap-3.5 font-mono text-xs tracking-widest uppercase opacity-75"
    >
      <span class="text-accent-text opacity-100">Case study, expanded</span>
      <span aria-hidden="true" class="bg-rule-bold h-px w-6"></span>
      <span>{bold.client} · {bold.location}</span>
    </div>

    <h2
      data-reveal
      data-d="1"
      class="font-display font-display-xl m-0 mb-[60px] max-w-[15ch] text-[clamp(48px,6.4vw,116px)] leading-[0.96] font-[340] tracking-[-0.035em] text-pretty"
    >
      <span>{titleHead} </span><em class="text-accent-text font-[320] italic">{titleTail}</em>.
    </h2>

    <div
      data-reveal
      data-d="2"
      class="grid grid-cols-1 items-start gap-8 md:grid-cols-[1.2fr_1fr] md:gap-20"
    >
      <p class="m-0 max-w-[46ch] text-[21px] leading-[1.55] font-normal">{bold.summary}</p>

      <dl class="m-0 font-mono text-xs leading-[1.9] opacity-90">
        {
          meta.map(([k, v]) => (
            <div class="border-rule-bold flex justify-between border-t py-1.5">
              <dt class="tracking-[0.06em] uppercase opacity-65">{k}</dt>
              <dd class="m-0">{v}</dd>
            </div>
          ))
        }
      </dl>
    </div>

    <div
      data-reveal
      data-d="3"
      class="border-rule-bold mt-14 grid gap-6 border-t pt-8 sm:grid-cols-2 sm:gap-8 md:mt-20 md:grid-cols-[repeat(var(--pillar-cols,3),1fr)] md:gap-10 md:pt-9"
      style={`--pillar-cols:${bold.pillars.length}`}
    >
      {
        bold.pillars.map(([k, v], i) => (
          <div>
            <div class="text-accent-text mb-3.5 font-mono text-[11px] tracking-widest uppercase">
              {String(i + 1).padStart(2, '0')} · {k}
            </div>
            <div class="font-display font-display-sm text-[22px] leading-[1.3] font-[380] tracking-[-0.012em]">
              {v}
            </div>
          </div>
        ))
      }
    </div>

    <div data-reveal data-d="4" class="mt-12 flex flex-wrap gap-2 md:mt-[60px]">
      {
        bold.stack.map((s) => (
          <span class="border-rule-bold rounded-full border px-2.5 py-1 font-mono text-[11px] tracking-wider">
            {s}
          </span>
        ))
      }
    </div>
  </div>
</section>
