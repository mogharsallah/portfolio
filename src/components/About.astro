---
import { Image } from 'astro:assets';
import { loadPortfolio } from '../lib/resume.ts';

const PORTFOLIO = await loadPortfolio();
import portrait from '../assets/portrait.webp';

const sectionEyebrow = 'font-mono text-[11px] tracking-[0.1em] uppercase text-ink-soft';
const monoMeta = 'font-mono text-[11px] tracking-[0.06em] uppercase text-ink-soft';
---

<section id="about" data-nav="about" data-reveal class="bg-paper-deep px-gutter py-[130px]">
  <div class="container-page">
    <div class:list={[sectionEyebrow, 'mb-12']}>About</div>

    <div class="grid grid-cols-1 gap-8 md:grid-cols-[1fr_2fr] md:items-stretch md:gap-20">
      <div
        class="bg-bold relative aspect-square overflow-hidden shadow-[0_1px_0_rgba(0,0,0,0.08)] md:aspect-auto md:h-full"
      >
        <Image
          src={portrait}
          alt={`${PORTFOLIO.name}, photographed in Hamburg`}
          loading="lazy"
          decoding="async"
          widths={[480, 720, 960]}
          sizes="(max-width: 880px) 100vw, 33vw"
          class="absolute inset-0 size-full object-cover dark:brightness-[0.92]"
        />
        <div
          aria-hidden="true"
          class="pointer-events-none absolute inset-0 bg-[linear-gradient(180deg,transparent_50%,rgba(0,0,0,0.35)_100%)]"
        >
        </div>
        <div
          class="text-bold-fg absolute bottom-3 left-3.5 font-mono text-[10px] tracking-[0.08em] uppercase"
        >
          Hamburg · 2026
        </div>
      </div>

      <div>
        <h2
          class="font-display font-display-xl m-0 mb-10 max-w-[20ch] text-[clamp(36px,4.6vw,68px)] leading-[1.05] font-[340] tracking-tight"
        >
          Ten years of shipping, mostly in <em class="text-accent-text italic">Hamburg.</em>
        </h2>
        {
          PORTFOLIO.about.paragraphs.map((p) => (
            <p class="m-0 mb-[18px] text-[18px] leading-[1.6] text-pretty">{p}</p>
          ))
        }

        <div class="border-rule mt-12 grid grid-cols-2 gap-5 border-t pt-6 md:grid-cols-4">
          {
            PORTFOLIO.about.languages.map((l) => (
              <div>
                <div class="text-ink-soft mb-1 font-mono text-[10px] tracking-[0.08em] uppercase">
                  {l.level}
                </div>
                <div class="font-display font-display-sm text-[22px] font-[380] tracking-[-0.01em]">
                  {l.name}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <div data-reveal class="container-page mt-[120px]">
    <header class="border-rule mb-9 flex items-baseline justify-between border-b pb-[18px]">
      <h3 class="font-display font-display-xl m-0 text-[36px] font-[350] tracking-[-0.02em]">
        Currently <em class="italic">/now</em>
      </h3>
      <span class={monoMeta}>Updated April 2026</span>
    </header>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 md:grid-cols-4 md:gap-8">
      {
        PORTFOLIO.now.map((n) => (
          <div>
            <div class="text-accent-text mb-2.5 font-mono text-[10px] tracking-widest uppercase">
              {n.kind}
            </div>
            <div class="font-display font-display-sm text-[19px] leading-[1.35] font-[380]">
              {n.text}
            </div>
          </div>
        ))
      }
    </div>
  </div>

  <div
    data-reveal
    class="container-page mt-[100px] grid grid-cols-1 gap-8 sm:grid-cols-2 sm:gap-12 md:gap-20"
  >
    <div>
      <div class:list={[sectionEyebrow, 'mb-6']}>Side projects</div>
      {
        PORTFOLIO.side.map((s) => (
          <div class="border-rule grid grid-cols-[60px_1fr] gap-4 border-t py-3.5">
            <span class="text-ink-soft pt-[5px] font-mono text-[11px]">{s.year}</span>
            <div>
              <div class="font-display font-display-sm text-[19px] font-normal tracking-[-0.01em]">
                {s.name}
              </div>
              <div class="text-ink-soft mt-[3px] text-[13px]">{s.note}</div>
            </div>
          </div>
        ))
      }
    </div>
    <div>
      <div class:list={[sectionEyebrow, 'mb-6']}>Open source</div>
      {
        PORTFOLIO.oss.map((o) => (
          <div class="border-rule border-t py-3.5">
            <div class="flex items-baseline justify-between">
              <span class="font-display font-display-sm text-[19px] font-normal tracking-[-0.01em]">
                {o.repo}
              </span>
              <span class="text-accent-text font-mono text-[11px]">{o.stars}</span>
            </div>
            <div class="text-ink-soft mt-[3px] text-[13px]">{o.note}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>
