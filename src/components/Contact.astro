---
import { loadPortfolio } from '../lib/resume.ts';

const PORTFOLIO = await loadPortfolio();

const [emailUser, emailDomain] = PORTFOLIO.email.split('@');

const valueLink =
  'inline-block max-w-full font-display font-display-sm text-[24px] font-[380] text-ink no-underline ' +
  'border-b border-rule pb-1 transition-[color,border-color] duration-200 ' +
  'hover:text-accent-text hover:border-accent-text [overflow-wrap:anywhere] break-words';
---

<section
  id="contact"
  data-nav="contact"
  data-reveal
  class="border-rule px-gutter border-t pt-32.5 pb-15"
>
  <div class="container-page">
    <div class="text-ink-soft mb-8 font-mono text-xs tracking-widest uppercase">✦ let's talk</div>

    <h2
      class="font-display font-display-xl m-0 mb-16 max-w-[11ch] text-[clamp(64px,9vw,168px)] leading-[0.92] font-[320] tracking-[-0.045em]"
    >
      Got a <em class="text-accent-text font-[320] italic">tough</em> problem?
    </h2>

    <div
      class="border-rule grid grid-cols-1 gap-7 border-t pt-7 sm:grid-cols-2 sm:gap-8 md:grid-cols-3"
    >
      <div>
        <div class="text-ink-soft mb-3 font-mono text-[10.5px] tracking-widest uppercase">
          Email
        </div>
        <a
          class={valueLink}
          href={`mailto:${emailUser}@${emailDomain}`}
          data-email
          data-email-user={emailUser}
          data-email-domain={emailDomain}>{PORTFOLIO.email}</a
        >
      </div>
      <div>
        <div class="text-ink-soft mb-3 font-mono text-[10.5px] tracking-widest uppercase">
          GitHub
        </div>
        <a class={valueLink} href={`https://${PORTFOLIO.github}`} rel="me noopener"
          >{PORTFOLIO.github}</a
        >
      </div>
      <div>
        <div class="text-ink-soft mb-3 font-mono text-[10.5px] tracking-widest uppercase">Site</div>
        <a class={valueLink} href={`https://${PORTFOLIO.site}`}>{PORTFOLIO.site}</a>
      </div>
    </div>

    <div
      class="border-rule text-ink-soft mt-25 flex flex-wrap items-center gap-x-4 gap-y-2 border-t pt-6 font-mono text-[11px] tracking-[0.06em] uppercase"
    >
      <span>© 2026 · {PORTFOLIO.name}</span>
      <span aria-hidden="true" class="opacity-50 sm:hidden">·</span>
      <a
        href="https://github.com/mogharsallah/portfolio"
        rel="noopener"
        class="hover:text-accent-text inline-flex items-center gap-1.5 text-inherit no-underline transition-colors duration-200 sm:ml-auto"
      >
        <svg
          aria-hidden="true"
          width="12"
          height="12"
          viewBox="0 0 16 16"
          fill="currentColor"
          class="flex-none"
        >
          <path
            d="M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"
          ></path>
        </svg>
        Source
      </a>
    </div>
  </div>
</section>
